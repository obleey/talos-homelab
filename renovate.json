{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabled": true,
  "timezone": "Europe/Ljubljana",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "automerge": false,
  "labels": ["renovate"],
  "helm-values": {
    "fileMatch": ["(^|/).*values\\.yaml$"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/(^|/)deployments/.+\\.yaml$/"]
  },
  "argocd": {
    "managerFilePatterns": ["/(^|/)deployments/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values", "argocd"],
      "groupName": "helm charts"
    },
    {
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "kubernetes manifests"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "lscr.io/linuxserver/sonarr",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/bazarr",
        "lscr.io/linuxserver/prowlarr",
        "lscr.io/linuxserver/qbittorrent"
      ],
      "groupName": "media stack",
      "versioning": "loose",
      "allowedVersions": "!/nightly|develop|beta|alpha|[0-9a-f]{6,}-/",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/lscr\\.io\\/linuxserver\\/.*/"],
      "groupName": "linuxserver images",
      "versioning": "loose",
      "allowedVersions": "!/nightly|develop|beta|alpha|[0-9a-f]{6,}-/",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/ghcr\\.io\\/.*/"],
      "groupName": "ghcr images",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golift/unpackerr", "plexinc/pms-docker", "jellyfin/jellyfin"],
      "groupName": "docker hub images",
      "versioning": "loose",
      "allowedVersions": "!/-(armhf|amd64|arm64)$/",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["jellyfin/jellyfin"],
      "allowedVersions": "!/^(12|13|14)/",
      "versioning": "loose"
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["renovate", "major-update"]
    },
    {
      "matchPackageNames": [
        "registry.k8s.io/metrics-server/metrics-server"
      ],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/thephaseless/byparr"],
      "updateTypes": ["digest"],
      "enabled": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/dan-online/autopulse"],
      "updateTypes": ["digest"],
      "enabled": true
    }
  ]
}
