{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabled": true,
  "mode": "normal",
  "timezone": "Europe/Ljubljana",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "automerge": false,
  "labels": ["renovate"],
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/).*values\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)deployments/.+\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "groupName": "helm charts",
      "automerge": false
    },
    {
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "kubernetes manifests",
      "automerge": false
    },
    {
      "groupName": "linuxserver images",
      "automerge": false,
      "matchPackageNames": [
        "/lscr.io/linuxserver/*/"
      ]
    },
    {
      "groupName": "ghcr images",
      "automerge": false,
      "matchPackageNames": [
        "/ghcr.io/*/"
      ]
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "major-update"],
      "matchPackageNames": [
        "/.*/"
      ]
    }
  ],
  "argocd": {
    "managerFilePatterns": [
      "/(^|/)deployments/.+\.yaml$/"
    ]
  }
}
