{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabled": true,
  "timezone": "Europe/Ljubljana",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10,
  "automerge": false,
  "labels": ["renovate"],
  "customDatasources": {
    "plex": {
      "defaultRegistryUrlTemplate": "https://plex.tv/api/downloads/5.json",
      "transformTemplates": [
        "{\"releases\": [{\"version\": $$.computer.Linux.version}]}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/).*values\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+) versioning=(?<versioning>[^\\s]+)\\n\\s+tag: \"(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "helm-values": {
    "fileMatch": ["(^|/).*values\\.yaml$"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/(^|/)deployments/.+\\.yaml$/"]
  },
  "argocd": {
    "managerFilePatterns": ["/(^|/)deployments/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "groupName": "helm charts"
    },
    {
      "matchManagers": ["kubernetes"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "kubernetes manifests"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "lscr.io/linuxserver/sonarr",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/bazarr",
        "lscr.io/linuxserver/prowlarr",
        "lscr.io/linuxserver/qbittorrent"
      ],
      "groupName": "media stack",
      "versioning": "loose",
      "allowedVersions": "!/nightly|develop|beta|alpha|[0-9a-f]{6,}-/",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/lscr\\.io\\/linuxserver\\/.*/"],
      "groupName": "linuxserver images",
      "versioning": "loose",
      "allowedVersions": "!/nightly|develop|beta|alpha|[0-9a-f]{6,}-/",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/ghcr\\.io\\/.*/"],
      "groupName": "ghcr images",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["golift/unpackerr"],
      "groupName": "docker hub images",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["renovate", "major-update"]
    },
    {
      "matchPackageNames": [
        "registry.k8s.io/metrics-server/metrics-server"
      ],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/thephaseless/byparr"],
      "updateTypes": ["digest"],
      "enabled": true
    }
  ]
}
